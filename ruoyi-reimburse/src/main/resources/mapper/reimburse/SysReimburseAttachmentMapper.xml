<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.reimburse.mapper.SysReimburseAttachmentMapper">

    <resultMap type="SysReimburseAttachment" id="SysReimburseAttachmentResult">
        <result property="attachmentId"    column="attachment_id"    />
        <result property="reimburseId"    column="reimburse_id"    />
        <result property="fileName"    column="file_name"    />
        <result property="filePath"    column="file_path"    />
        <result property="thumbnailUrl"    column="thumbnail_url"    />
        <result property="fileSize"    column="file_size"    />
        <result property="fileType"    column="file_type"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
    </resultMap>

    <sql id="selectSysReimburseAttachmentVo">
        select attachment_id, reimburse_id, file_name, file_path, thumbnail_url, file_size, file_type, create_by, create_time from sys_reimburse_attachment
    </sql>

    <select id="selectSysReimburseAttachmentList" parameterType="SysReimburseAttachment" resultMap="SysReimburseAttachmentResult">
        <include refid="selectSysReimburseAttachmentVo"/>
        <where>
            <if test="reimburseId != null "> and reimburse_id = #{reimburseId}</if>
            <if test="fileName != null  and fileName != ''"> and file_name like concat('%', #{fileName}, '%')</if>
            <if test="filePath != null  and filePath != ''"> and file_path = #{filePath}</if>
            <if test="fileSize != null "> and file_size = #{fileSize}</if>
            <if test="fileType != null  and fileType != ''"> and file_type = #{fileType}</if>
        </where>
    </select>

    <select id="selectSysReimburseAttachmentByAttachmentId" parameterType="Long" resultMap="SysReimburseAttachmentResult">
        <include refid="selectSysReimburseAttachmentVo"/>
        where attachment_id = #{attachmentId}
    </select>

    <insert id="insertSysReimburseAttachment" parameterType="SysReimburseAttachment" useGeneratedKeys="true" keyProperty="attachmentId">
        insert into sys_reimburse_attachment
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="reimburseId != null">reimburse_id,</if>
            <if test="fileName != null and fileName != ''">file_name,</if>
            <if test="filePath != null and filePath != ''">file_path,</if>
            <if test="thumbnailUrl != null and thumbnailUrl != ''">thumbnail_url,</if>
            <if test="fileSize != null">file_size,</if>
            <if test="fileType != null and fileType != ''">file_type,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="reimburseId != null">#{reimburseId},</if>
            <if test="fileName != null and fileName != ''">#{fileName},</if>
            <if test="filePath != null and filePath != ''">#{filePath},</if>
            <if test="thumbnailUrl != null and thumbnailUrl != ''">#{thumbnailUrl},</if>
            <if test="fileSize != null">#{fileSize},</if>
            <if test="fileType != null and fileType != ''">#{fileType},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
         </trim>
    </insert>

    <update id="updateSysReimburseAttachment" parameterType="SysReimburseAttachment">
        update sys_reimburse_attachment
        <trim prefix="SET" suffixOverrides=",">
            <if test="reimburseId != null">reimburse_id = #{reimburseId},</if>
            <if test="fileName != null and fileName != ''">file_name = #{fileName},</if>
            <if test="filePath != null and filePath != ''">file_path = #{filePath},</if>
            <if test="thumbnailUrl != null and thumbnailUrl != ''">thumbnail_url = #{thumbnailUrl},</if>
            <if test="fileSize != null">file_size = #{fileSize},</if>
            <if test="fileType != null and fileType != ''">file_type = #{fileType},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
        </trim>
        where attachment_id = #{attachmentId}
    </update>

    <delete id="deleteSysReimburseAttachmentByAttachmentId" parameterType="Long">
        delete from sys_reimburse_attachment where attachment_id = #{attachmentId}
    </delete>

    <delete id="deleteSysReimburseAttachmentByAttachmentIds" parameterType="String">
        delete from sys_reimburse_attachment where attachment_id in
        <foreach item="attachmentId" collection="array" open="(" separator="," close=")">
            #{attachmentId}
        </foreach>
    </delete>
    <delete id="deleteSysReimburseAttachmentByReimburseId">
        delete from sys_reimburse_attachment where reimburse_id = #{reimburseId}
    </delete>
</mapper>
